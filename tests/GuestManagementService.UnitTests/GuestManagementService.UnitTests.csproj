<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>

    <!-- Exclude EF Core-generated migrations and the model snapshot from coverage.
         These are auto-generated boilerplate that is not unit-tested; counting them
         skews the diff-coverage gate. -->
    <ExcludeByFile>**/Persistence/Migrations/*.cs</ExcludeByFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.0" />
    <PackageReference Include="coverlet.msbuild" Version="6.0.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" />
    <PackageReference Include="Moq" Version="4.17.2" />
    <PackageReference Include="xunit" Version="2.5.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.3" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\GuestManagementService.Api\GuestManagementService.Api.csproj" />
    <ProjectReference Include="..\..\src\GuestManagementService.Application\GuestManagementService.Application.csproj" />
    <ProjectReference Include="..\..\src\GuestManagementService.Contracts\GuestManagementService.Contracts.csproj" />
    <ProjectReference Include="..\..\src\GuestManagementService.Domain\GuestManagementService.Domain.csproj" />
  </ItemGroup>

</Project>
